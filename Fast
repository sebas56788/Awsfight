-- ===== AUTO CRITIC HANDLER (SISTEMA ORIGINAL) =====
AutoCriticToggle:OnChanged(function(state)
    if state then
        -- Crear threads para Auto Critic (igual que el sistema original)
        for _, thread in pairs(autoCriticThreads) do
            if typeof(thread) == "thread" then
                task.cancel(thread)
            elseif typeof(thread) == "table" then
                thread.active = false
            end
        end
        autoCriticThreads = {}
        
        if cleanupConnections.autoCritic then
            cleanupConnections.autoCritic:Disconnect()
        end
        
        -- Crear 100 threads para Auto Critic
        for i = 1, 100 do
            local threadData = { active = true }
            table.insert(autoCriticThreads, threadData)
            
            task.spawn(function()
                while threadData.active and AutoCriticToggle.Value do
                    pcall(function()
                        ArmwrestleServiceRF.RequestCritHit:InvokeServer()
                    end)
                    task.wait(1) -- 1 segundo entre critical hits
                end
            end)
            task.wait(0.001)
        end
        
        cleanupConnections.autoCritic = task.spawn(function()
            while AutoCriticToggle.Value do
                task.wait(5)
                if AutoCriticToggle.Value then
                    cleanupRequests()
                end
            end
        end)
        
        Library:Notify("Auto Critic Hit ACTIVATED", 3)
    else
        -- Detener threads
        for _, thread in pairs(autoCriticThreads) do
            if typeof(thread) == "thread" then
                task.cancel(thread)
            elseif typeof(thread) == "table" then
                thread.active = false
            end
        end
        autoCriticThreads = {}
        
        if cleanupConnections.autoCritic then
            task.cancel(cleanupConnections.autoCritic)
            cleanupConnections.autoCritic = nil
        end
        cleanupRequests()
        
        Library:Notify("Auto Critic Hit DEACTIVATED", 3)
    end
end)

