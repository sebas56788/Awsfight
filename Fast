-- ===== ESCUCHADOR DE CRÍTICOS (CORREGIDO CON LA SEÑAL RE) =====
AutoCriticToggle:OnChanged(function(state)
    if state then
        if criticConnection then criticConnection:Disconnect() end
        
        -- Escucha cuando el juego spawnea un crítico y lo activa al instante
        criticConnection = SpawnCritSignal.OnClientEvent:Connect(function()
            if AutoCriticToggle.Value then
                pcall(function()
                    RequestCritHit:InvokeServer()
                end)
            end
        end)
        
        -- Por si acaso, un bucle secundario de respaldo rápido
        task.spawn(function()
            while AutoCriticToggle.Value do
                pcall(function()
                    RequestCritHit:InvokeServer()
                end)
                task.wait(0.3)
            end
        end)
        
        Library:Notify("Auto Critic Hit ACTIVATED", 3)
    else
        if criticConnection then
            criticConnection:Disconnect()
            criticConnection = nil
        end
        Library:Notify("Auto Critic Hit DEACTIVATED", 3)
    end
end)

-- ===== AUTO CLICK HANDLER (SISTEMA SEGURO Y ULTRA RÁPIDO) =====
AutoClickToggle:OnChanged(function(state)
    if state then
        local clickDelay = ClickSpeedSlider.Value / 1000
        
        for _, thread in pairs(autoClickThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoClickThreads = {}
        
        -- 5 Hilos rápidos dedicados para móvil sin congelar el juego
        for i = 1, 5 do
            local threadData = { active = true }
            table.insert(autoClickThreads, threadData)
            
            task.spawn(function()
                while threadData.active and AutoClickToggle.Value do
                    pcall(function()
                        RequestClick:InvokeServer()
                    end)
                    task.wait(clickDelay)
                end
            end)
            task.wait(0.005)
        end
        
        Library:Notify("Auto Click ACTIVATED (" .. ClickSpeedSlider.Value .. "ms)", 3)
    else
        for _, thread in pairs(autoClickThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoClickThreads = {}
        cleanupRequests()
        Library:Notify("Auto Click DEACTIVATED", 3)
    end
end)

