AutoSpinToggle:OnChanged(function()
    if AutoSpinToggle.Value then
        spawn(function()
            while AutoSpinToggle.Value do
                local selectedWheel = wheelDropdown.Value
                local spinAmount = SpinAmountDropdown.Value
                
                if selectedWheel and selectedWheel ~= "" then
                    local args = {
                        [1] = selectedWheel,
                        [2] = spinAmount == "3x" and "x10" or spinAmount == "10x" and "x25" or nil
                    }
                    
                    pcall(function()
                        SpinnerServiceRF.Spin:InvokeServer(unpack(args))
                    end)
                end
                
                wait(1)
            end
        end)
    end
end)

