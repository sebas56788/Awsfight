-- FUNCIÓN PARA ACTUALIZAR LA UI
local function updateUI()
    local elapsed = tick() - startTime
    local eggsPerSecond = eggsOpened / elapsed
    
    labels[1].Text = "Eggs Abiertos: " .. eggsOpened
    labels[2].Text = "Tiempo: " .. string.format("%.1fs", elapsed)
    labels[3].Text = "Velocidad: " .. string.format("%.1f/s", eggsPerSecond)
    labels[4].Text = "Proyección: " .. string.format("%.0f/h", eggsPerSecond * 3600)
    
    -- CAMBIAR COLOR SEGÚN VELOCIDAD
    if eggsPerSecond > 100 then
        labels[3].TextColor3 = Color3.new(0, 1, 0) -- Verde
        titleBg.BackgroundColor3 = Color3.new(0, 1, 0) -- Verde
    elseif eggsPerSecond > 50 then
        labels[3].TextColor3 = Color3.new(1, 1, 0) -- Amarillo
        titleBg.BackgroundColor3 = Color3.new(1, 1, 0) -- Amarillo
    else
        labels[3].TextColor3 = Color3.new(1, 0, 0) -- Rojo
        titleBg.BackgroundColor3 = Color3.new(1, 0, 0) -- Rojo
    end
end

-- FUNCIÓN OVERKILL CON CONTADOR
local function OVERKILL_WITH_COUNTER()
    while true do
        for _ = 1, 50 do
            pcall(function()
                EggRemote:InvokeServer(eggName, nil, nil, false, nil, true)
                eggsOpened = eggsOpened + 1
            end)
        end
        task.wait(0.0001)
    end
end

-- MOSTRAR INICIO
print("\n🎯 INICIANDO EGG OVERKILL CON CONTADOR EN UI...")

-- CREAR HILOS
for i = 1, 200 do
    task.spawn(OVERKILL_WITH_COUNTER)
end

-- ACTUALIZAR UI CADA 0.1 SEGUNDOS
task.spawn(function()
    while true do
        task.wait(0.1)
        updateUI()
    end
end)

-- CONTADOR EN CONSOLA CADA SEGUNDO
task.spawn(function()
    while true do
        task.wait(1)
        local elapsed = tick() - startTime
        local eggsPerSecond = eggsOpened / elapsed
        
        print(string.format("📊 [LIVE] %d eggs | %.1f/s | %.1f/m | %d/h", 
              eggsOpened, eggsPerSecond, eggsPerSecond * 60, eggsPerSecond * 3600))
    end
end)

-- HACER LA UI ARRASTRABLE (MEJORADO)
local UserInputService = game:GetService("UserInputService")
local dragging = false
local dragStart, startPos

titleBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X,
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- INICIALIZAR UI
updateUI()
print("✅ UI CENTRADA INICIALIZADA - Puedes arrastrar desde la barra roja")
print("📍 Ubicación: Centro de la pantalla")
print("🖱️  Para mover: Haz clic en la barra roja y arrastra")
