-- FUNCION PARA DETECTAR TODOS LOS BOSSES
local function GetAllBosses()
    local allBosses = {}
    local gameObjects = workspace:FindFirstChild("GameObjects")
    if gameObjects then
        local armWrestling = gameObjects:FindFirstChild("ArmWrestling")
        if armWrestling then
            for _, zoneFolder in pairs(armWrestling:GetChildren()) do
                if zoneFolder:IsA("Folder") then
                    local npcFolder = zoneFolder:FindFirstChild("NPC")
                    if npcFolder then
                        for _, boss in pairs(npcFolder:GetChildren()) do
                            if boss:IsA("Model") then table.insert(allBosses, boss.Name) end
                        end
                    end
                end
            end
        end
    end
    
    local zones = workspace:FindFirstChild("Zones")
    if zones then
        for _, zone in pairs(zones:GetChildren()) do
            if zone:IsA("Folder") then
                local interactables = zone:FindFirstChild("Interactables")
                if interactables then
                    local bosses = interactables:FindFirstChild("Bosses")
                    if bosses then
                        for _, boss in pairs(bosses:GetChildren()) do
                            if boss:IsA("Model") then table.insert(allBosses, boss.Name) end
                        end
                    end
                end
            end
        end
    end
    
    local uniqueBosses = {}
    for _, boss in pairs(allBosses) do uniqueBosses[boss] = true end
    local finalBosses = {}
    for boss in pairs(uniqueBosses) do table.insert(finalBosses, boss) end
    table.sort(finalBosses)
    return finalBosses
end

