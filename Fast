            while AutoSpinToggle.Value do
                local selectedWheel = wheelDropdown.Value
                local spinAmount = SpinAmountDropdown.Value
                if selectedWheel and selectedWheel ~= "" then
                    local mode = nil
                    if spinAmount == "3x" then mode = "x10" end
                    if spinAmount == "10x" then mode = "x25" end
                    pcall(function() SpinnerSpin:InvokeServer(selectedWheel, mode) end)
                end
                task.wait(1)
            end
        end)
    end
end)

