-- Adaptador inteligente para RF o RE (Evita que se rompa si el juego actualiza)
local function safeRemoteCall(serviceFolder, remoteName, ...)
    local args = {...}
    pcall(function()
        -- Intenta primero buscar en la carpeta RE (RemoteEvent)
        local reFolder = serviceFolder:FindFirstChild("RE")
        if reFolder and reFolder:FindFirstChild(remoteName) then
            reFolder[remoteName]:FireServer(unpack(args))
            return
        end
        
        -- Si no, intenta en la carpeta RF (RemoteFunction)
        local rfFolder = serviceFolder:FindFirstChild("RF")
        if rfFolder and rfFolder:FindFirstChild(remoteName) then
            rfFolder[remoteName]:InvokeServer(unpack(args))
            return
        end
        
        -- Si están sueltos en el servicio
        if serviceFolder:FindFirstChild(remoteName) then
            local remote = serviceFolder[remoteName]
            if remote:IsA("RemoteEvent") then
                remote:FireServer(unpack(args))
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer(unpack(args))
            end
        end
    end)
end

