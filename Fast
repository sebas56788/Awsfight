-- ===== MANEJADOR DEL MEGAMODEL CLICK FÍSICO (MULTIHILO) =====
AutoClickToggle:OnChanged(function(state)
    autoClickActive = state
    if state then
        local delayTime = ClickSpeedSlider.Value / 1000
        
        -- Abrimos 4 hilos en paralelo sincronizados para generar una ráfaga masiva de toques
        for i = 1, 4 do
            task.spawn(function()
                while autoClickActive do
                    pcall(function()
                        local camera = workspace.CurrentCamera
                        if camera then
                            -- Calcula el centro exacto de tu pantalla de celular
                            local x = camera.ViewportSize.X * 0.5
                            local y = camera.ViewportSize.Y * 0.65 -- Posición perfecta para registrar clicks normales y críticos a la vez
                            
                            -- Enviar evento de pulsar pantalla
                            VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
                            task.wait(0.001)
                            -- Enviar evento de soltar pantalla
                            VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
                        end
                    end)
                    task.wait(delayTime)
                end
            end)
            task.wait(0.002) -- Micro-retraso para intercalar las ráfagas
        end
        Library:Notify("¡Super Auto Clicker Activo!", 3)
    else
        Library:Notify("Auto Clicker Desactivado", 3)
    end
end)

-- Reiniciar automáticamente si el usuario cambia el Slider de velocidad en vivo
ClickSpeedSlider:OnChanged(function()
    if autoClickActive then
        AutoClickToggle:SetValue(false)
        task.wait(0.1)
        AutoClickToggle:SetValue(true)
    end
end)

-- ===== MANEJADOR DE AUTO LUCHA =====
AutoFightToggle:OnChanged(function(state)
    autoFightActive = state
    if state then
        task.spawn(function()
            while autoFightActive do
                local selectedName = modelDropdown.Value
                if selectedName and selectedName ~= "" then
                    pcall(function()
                        RequestStartFight:InvokeServer(selectedName)
                    end)
                end
                task.wait(0.4) -- Re-intenta entrar a la pelea de forma óptima
            end
        end)
        Library:Notify("Auto Lucha Iniciada", 3)
    else
        Library:Notify("Auto Lucha Detenida", 3)
    end
end)

