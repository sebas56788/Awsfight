-- ===== AUTO CRITIC HANDLER (CORREGIDO) =====
AutoCriticToggle:OnChanged(function(state)
    if state then
        for _, thread in pairs(autoCriticThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoCriticThreads = {}
        
        if cleanupConnections.autoCritic then task.cancel(cleanupConnections.autoCritic) end
        
        -- Optimizado a menos hilos pero más rápidos para evitar crasheos por spam excesivo
        for i = 1, 10 do
            local threadData = { active = true }
            table.insert(autoCriticThreads, threadData)
            
            task.spawn(function()
                while threadData.active and AutoCriticToggle.Value do
                    safeRemoteCall(ArmwrestleService, "RequestCritHit")
                    task.wait(0.1) -- Ajustado para ser ultra rápido sin romper el juego
                end
            end)
            task.wait(0.005)
        end
        
        cleanupConnections.autoCritic = task.spawn(function()
            while AutoCriticToggle.Value do
                task.wait(5)
                if AutoCriticToggle.Value then cleanupRequests() end
            end
        end)
        
        Library:Notify("Auto Critic Hit ACTIVATED", 3)
    else
        for _, thread in pairs(autoCriticThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoCriticThreads = {}
        
        if cleanupConnections.autoCritic then
            task.cancel(cleanupConnections.autoCritic)
            cleanupConnections.autoCritic = nil
        end
        cleanupRequests()
        Library:Notify("Auto Critic Hit DEACTIVATED", 3)
    end
end)

