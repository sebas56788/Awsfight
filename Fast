-- ===== NUEVO MANEJADOR DE CRITICO POR TOQUE VIRTUAL =====
AutoCriticToggle:OnChanged(function(state)
    autoCriticActive = state
    if state then
        task.spawn(function()
            while autoCriticActive do
                pcall(function()
                    -- Busca la interfaz del juego donde sale el botón de crítico de Arm Wrestle
                    local playerGui = Players.LocalPlayer:FindFirstChild("PlayerGui")
                    local gameGui = playerGui and (playerGui:FindFirstChild("GameGui") or playerGui:FindFirstChild("FightGui") or playerGui:FindFirstChild("ArmWrestleGui"))
                    
                    -- Si encuentra interfaces de pelea activas, hace clics virtuales en ráfaga en la zona central/baja
                    -- Usamos posiciones calculadas para que caiga justo sobre el botón de pulsar en celulares
                    local camera = workspace.CurrentCamera
                    if camera then
                        local x = camera.ViewportSize.X * 0.5
                        local y = camera.ViewportSize.Y * 0.75 -- Zona común del botón de crítico
                        
                        -- Genera el toque virtual de pantalla
                        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
                        task.wait(0.01)
                        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
                    end
                end)
                task.wait(0.05) -- Frecuencia ultra rápida de clicks de crítico
            end
        end)
        Library:Notify("Auto Critic (Virtual Input) ACTIVATED", 3)
    else
        Library:Notify("Auto Critic DEACTIVATED", 3)
    end
end)

-- ===== AUTO CLICK =====
AutoClickToggle:OnChanged(function(state)
    if state then
        local clickDelay = ClickSpeedSlider.Value / 1000
        for _, thread in pairs(autoClickThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoClickThreads = {}
        
        for i = 1, 5 do
            local threadData = { active = true }
            table.insert(autoClickThreads, threadData)
            
            task.spawn(function()
                while threadData.active and AutoClickToggle.Value do
                    pcall(function() RequestClick:InvokeServer() end)
                    task.wait(clickDelay)
                end
            end)
            task.wait(0.005)
        end
        Library:Notify("Auto Click ACTIVATED", 3)
    else
        for _, thread in pairs(autoClickThreads) do
            if typeof(thread) == "table" then thread.active = false end
        end
        autoClickThreads = {}
        cleanupRequests()
        Library:Notify("Auto Click DEACTIVATED", 3)
    end
end)

ClickSpeedSlider:OnChanged(function(value)
